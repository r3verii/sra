        "id": "rb-rails-session",
        "pattern": "\\bsession\\[\\s*:|cookies\\[\\s*:|cookies\\.(?:permanent|encrypted|signed)\\b",
        "description": "Rails session / cookies access",
        "expected_role": "identity_source",
        "false_positive_notes": "Stable."
      }
