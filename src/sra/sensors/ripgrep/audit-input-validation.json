{
  "schema_version": 1,
  "sensor": "ripgrep",
  "family": "audit/input-validation",
  "description": "Seed patterns for the audit/input-validation family. Hits are evidence-seeds for a downstream Claude skill, not findings. Patterns are deliberately broad; the skill confirms or dismisses each hit by reading surrounding code.",
  "notes": [
    "ripgrep uses Rust regex syntax. \\b word boundaries supported.",
    "Pattern IDs are unique within this file and stable; downstream artefacts reference them by id.",
    "expected_role drives how the packet builder groups hits inside each packet."
  ],
  "groups": {
    "javascript_typescript": [
      {
        "id": "js-req-body",
        "pattern": "\\breq\\.body\\b",
        "description": "Express / Connect request body access",
        "expected_role": "input_source",
        "false_positive_notes": "Any variable named req matches; check function signature."
      },
      {
        "id": "js-req-query",
        "pattern": "\\breq\\.query\\b",
        "description": "Express request query string access",
        "expected_role": "input_source",
        "false_positive_notes": "Same as js-req-body."
      },
      {
        "id": "js-req-params",
        "pattern": "\\breq\\.params\\b",
        "description": "Express route params access",
        "expected_role": "input_source",
        "false_positive_notes": "Same as js-req-body."
      },
      {
        "id": "js-req-headers",
        "pattern": "\\breq\\.headers\\b",
        "description": "Express request headers access",
        "expected_role": "input_source",
        "false_positive_notes": "Same as js-req-body."
      },
      {
        "id": "js-ctx-body",
        "pattern": "\\bctx\\.(?:request\\.)?body\\b",
        "description": "Koa context body access",
        "expected_role": "input_source",
        "false_positive_notes": "ctx is a common name; verify framework import."
      },
      {
        "id": "js-fastify-request-body",
        "pattern": "\\brequest\\.body\\b",
        "description": "Fastify request body access",
        "expected_role": "input_source",
        "false_positive_notes": "Fires in any code that uses a 'request' variable."
      },
      {
        "id": "js-express-json-middleware",
        "pattern": "\\bexpress\\.json\\(",
        "description": "Express built-in JSON body parser",
        "expected_role": "parser_middleware",
        "false_positive_notes": "Appears in examples and tests as well as production."
      },
      {
        "id": "js-express-urlencoded",
        "pattern": "\\bexpress\\.urlencoded\\(",
        "description": "Express built-in URL-encoded body parser",
        "expected_role": "parser_middleware",
        "false_positive_notes": "Same as js-express-json-middleware."
      },
      {
        "id": "js-body-parser",
        "pattern": "\\bbody-?[Pp]arser\\b",
        "description": "body-parser / bodyParser middleware",
        "expected_role": "parser_middleware",
        "false_positive_notes": "Matches both the dependency name and the symbol."
      },
      {
        "id": "js-multer",
        "pattern": "\\bmulter\\(",
        "description": "multer multipart middleware",
        "expected_role": "parser_middleware",
        "false_positive_notes": "Low FP rate; fairly unique name."
      },
      {
        "id": "js-zod-import",
        "pattern": "from ['\"]zod['\"]",
        "description": "zod validator import",
        "expected_role": "validator",
        "false_positive_notes": "ES module import only; CommonJS require not matched here."
      },
      {
        "id": "js-joi-import",
        "pattern": "require\\(['\"]joi['\"]\\)|from ['\"]joi['\"]",
        "description": "Joi validator import",
        "expected_role": "validator",
        "false_positive_notes": "None significant."
      },
      {
        "id": "js-class-validator-import",
        "pattern": "from ['\"]class-validator['\"]",
        "description": "class-validator decorator-based validation",
        "expected_role": "validator",
        "false_positive_notes": "Typescript only."
      },
      {
        "id": "js-ajv-import",
        "pattern": "require\\(['\"]ajv['\"]\\)|from ['\"]ajv['\"]",
        "description": "ajv JSON Schema validator import",
        "expected_role": "validator",
        "false_positive_notes": "None significant."
      },
      {
        "id": "js-express-import",
        "pattern": "require\\(['\"]express['\"]\\)|from ['\"]express['\"]",
        "description": "Express framework import marker",
        "expected_role": "framework_marker",
        "false_positive_notes": "Identifies an entrypoint file."
      },
      {
        "id": "js-koa-import",
        "pattern": "require\\(['\"]koa['\"]\\)|from ['\"]koa['\"]",
        "description": "Koa framework import marker",
        "expected_role": "framework_marker",
        "false_positive_notes": "None significant."
      },
      {
        "id": "js-fastify-import",
        "pattern": "require\\(['\"]fastify['\"]\\)|from ['\"]fastify['\"]",
        "description": "Fastify framework import marker",
        "expected_role": "framework_marker",
        "false_positive_notes": "None significant."
      }
    ],
    "python": [
