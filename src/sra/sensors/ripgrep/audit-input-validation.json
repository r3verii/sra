        "expected_role": "input_source",
        "false_positive_notes": "Uppercase keys are Django-specific; lowercase ones overlap with Flask."
      },
      {
        "id": "py-fastapi-body",
        "pattern": "\\bBody\\(|\\bQuery\\(|\\bPath\\(|\\bHeader\\(|\\bForm\\(",
        "description": "FastAPI parameter / body declarations",
        "expected_role": "input_source",
        "false_positive_notes": "Capitalised names are common; will match unrelated callables."
      },
      {
        "id": "py-pydantic-basemodel",
        "pattern": "\\bBaseModel\\b",
        "description": "Pydantic schema base class",
        "expected_role": "validator",
        "false_positive_notes": "Any class named or containing BaseModel matches."
      },
      {
        "id": "py-flask-import",
        "pattern": "^\\s*from flask import|^\\s*import flask\\b",
        "description": "Flask framework import marker",
        "expected_role": "framework_marker",
        "false_positive_notes": "Anchored on line start to reduce FPs."
      },
      {
        "id": "py-django-urls-import",
        "pattern": "from django\\.urls import|from django\\.http import",
        "description": "Django routing / http imports",
        "expected_role": "framework_marker",
        "false_positive_notes": "None significant."
      },
      {
        "id": "py-fastapi-import",
        "pattern": "from fastapi import",
        "description": "FastAPI framework import marker",
        "expected_role": "framework_marker",
        "false_positive_notes": "None significant."
      }
