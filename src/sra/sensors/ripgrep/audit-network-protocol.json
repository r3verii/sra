      },
      {
        "id": "ruby-net-server-libs",
        "pattern": "\\bWEBrick::(?:HTTPServer|HTTPRequest)\\b|\\bPuma::(?:Server|Configuration)\\b|\\bUnicorn::(?:HttpServer|Configurator)\\b|\\bThin::Server\\b|\\bFalcon::Server\\b",
        "description": "Ruby HTTP server implementations (Puma, WEBrick, Unicorn, Thin, Falcon)",
        "expected_role": "framework_marker",
