    "ruby": [
      {
        "id": "ruby-net-rack-middleware",
        "pattern": "\\bdef\\s+call\\s*\\(\\s*env\\s*\\)|\\bclass\\s+\\w+\\s+(?:include|extend)\\s+Rack::|\\bRack::(?:Builder|Middleware|Request|Response)\\b",
        "description": "Rack middleware definition — Ruby web server interface. The env Hash is the request boundary.",
        "expected_role": "header_parser",
