        "pattern": "\\b(?:Faye::WebSocket|EM::WebSocket|ActionCable::(?:Server|Connection|Channel)|WebSocket::EventMachine|websocket-driver)\\b",
        "description": "WebSocket handling — Faye, EM-WebSocket, ActionCable. Frame parsing + state lifecycle.",
        "expected_role": "header_parser",
        "false_positive_notes": "Stable. Audit frame size limits + auth on subscribe."
      },
      {
        "id": "ruby-net-grpc",
        "pattern": "\\b(?:GRPC|GRPC::ClientStub|GRPC::Core|grpc\\.start_server|grpc\\.run_till_terminated)\\b",
