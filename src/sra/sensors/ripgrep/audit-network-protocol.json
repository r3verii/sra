        "expected_role": "framework_marker",
        "false_positive_notes": "Stable."
      },
      {
        "id": "ruby-net-em-network",
        "pattern": "\\bEM::Deferrable\\b|\\bEM::Connection\\b|\\bEM\\.start_server\\b|\\bEM\\.connect\\b",
        "description": "EventMachine network primitives — raw TCP/UDP server/client",
