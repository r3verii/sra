      },
      {
        "id": "kotlin-ktor-client",
        "pattern": "\\bHttpClient\\s*\\(\\s*(?:CIO|OkHttp|Apache|Java|Jetty|Curl|Darwin)\\s*\\)|\\bHttpClient\\s*\\{",
        "description": "Ktor HttpClient with engine — investigate TLS config",
        "expected_role": "header_parser",
        "false_positive_notes": "Stable."
      },
      {
        "id": "kotlin-okhttp-client",
        "pattern": "\\bOkHttpClient\\.Builder\\s*\\(\\s*\\)|\\bOkHttpClient\\s*\\(\\s*\\)|\\.newCall\\s*\\(",
        "description": "OkHttp client (popular in Android + Kotlin server)",
        "expected_role": "header_parser",
        "false_positive_notes": "Stable."
      },
      {
        "id": "kotlin-retrofit",
        "pattern": "\\bRetrofit\\.Builder\\s*\\(\\s*\\)|@(?:GET|POST|PUT|DELETE|PATCH|HEAD|OPTIONS)\\s*\\(",
