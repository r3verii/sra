      },
      {
        "id": "java-runtime-exec-concat",
        "pattern": "\\bRuntime\\.getRuntime\\(\\)\\.exec\\s*\\(\\s*\\w+\\s*\\+|\\bProcessBuilder\\s*\\(\\s*[^)]*\\+",
