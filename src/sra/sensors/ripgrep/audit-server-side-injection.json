        "false_positive_notes": "Almost always a finding."
      },
      {
        "id": "java-velocity-evaluate",
        "pattern": "\\b(?:Velocity\\.evaluate|VelocityEngine|MergeTemplate)\\b|\\b\\.evaluate\\s*\\(\\s*\\w+\\s*,\\s*\\w+\\s*,\\s*\\w+\\s*,",
        "description": "Velocity template evaluation — SSTI risk if template is user-controlled",
        "expected_role": "ssti_sink",
        "false_positive_notes": "Risk is when template string itself is user-controlled."
      },
      {
        "id": "java-freemarker-process",
        "pattern": "\\b(?:freemarker\\.template|Template\\.process|Configuration\\.getTemplate)\\b",
        "description": "FreeMarker template processing — SSTI risk",
        "expected_role": "ssti_sink",
        "false_positive_notes": "Risk is when template string itself is user-controlled."
      },
      {
        "id": "java-thymeleaf-inline",
        "pattern": "th:inline|th:utext|th:text=\\s*['\"]\\$\\{\\s*[^}]*\\}",
        "description": "Thymeleaf inline expressions — SSTI/XSS risk with th:utext (unescaped)",
        "expected_role": "ssti_sink",
        "false_positive_notes": "th:utext skips escaping; investigate when input flows in."
      },
      {
        "id": "java-spel-expression",
        "pattern": "\\b(?:SpelExpressionParser|StandardEvaluationContext|@Value\\s*\\(\\s*['\"]#\\{)|parseExpression\\s*\\(",
        "description": "Spring Expression Language (SpEL) parsing — evaluation injection",
        "expected_role": "eval_sink",
        "false_positive_notes": "SpEL on user input is critical (CVE-2022-22963, Spring4Shell)."
      },
      {
        "id": "java-ldap-search",
        "pattern": "\\b(?:LdapTemplate|DirContext|InitialDirContext|ldapTemplate)\\.search\\s*\\(|\\bsearchFilter\\s*=\\s*['\"][^'\"]*['\"]\\s*\\+",
