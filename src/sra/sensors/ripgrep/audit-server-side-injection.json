{
  "schema_version": 1,
  "sensor": "ripgrep",
  "family": "audit/server-side-injection",
  "description": "Seed patterns for the audit/server-side-injection family. Hits target SQL / NoSQL injection sinks, command injection, server-side template injection (SSTI), expression-language evaluation, dynamic eval / import. The skill follows input flow from request to sink.",
  "notes": [
    "ORMs are mostly safe; the concerns are raw SQL APIs, string-concat queries, and `WHERE column LIKE %s` patterns.",
    "Command injection sinks (shell exec with user input) are nearly always worth review when present."
  ],
  "groups": {
    "javascript_typescript": [
      {
        "id": "js-raw-sql",
        "pattern": "\\.(?:query|execute|raw|exec)\\s*\\(\\s*[`'\"]?(?:SELECT|INSERT|UPDATE|DELETE|MERGE)\\s",
        "description": "Raw SQL execution APIs",
        "expected_role": "sql_sink",
        "false_positive_notes": "Stable; check parameter binding."
      },
      {
        "id": "js-template-string-sql",
        "pattern": "(?:query|execute|raw)\\s*\\(\\s*`[^`]*\\$\\{",
        "description": "Template-string SQL with ${} interpolation",
        "expected_role": "sql_sink",
        "false_positive_notes": "Almost always a finding when input flows in."
      },
      {
        "id": "js-exec-spawn",
        "pattern": "\\bchild_process\\.(?:exec|execSync|spawn|spawnSync|fork)\\s*\\(",
        "description": "Node child_process — command injection vector",
        "expected_role": "command_sink",
        "false_positive_notes": "`exec` shells; `spawn` with shell:true does too. `spawn` without shell is safer."
      },
      {
        "id": "js-eval",
        "pattern": "\\beval\\s*\\(|\\bnew\\s+Function\\s*\\(|\\bvm\\.(?:runInThisContext|runInNewContext|runInContext)\\s*\\(",
        "description": "JS dynamic code execution",
        "expected_role": "eval_sink",
        "false_positive_notes": "Almost always worth flagging."
      },
      {
        "id": "js-template-render-input",
        "pattern": "\\.(?:render|compile)\\s*\\(\\s*\\w+\\s*[,)]",
        "description": "Template render with possibly user-controlled template",
        "expected_role": "ssti_sink",
        "false_positive_notes": "Concern when the template STRING is user-controlled, not the data."
      },
      {
        "id": "js-sequelize-raw",
        "pattern": "\\b(?:sequelize\\.query\\s*\\(|Sequelize\\.literal\\s*\\(|\\.literal\\s*\\(\\s*`|QueryTypes\\.RAW)\\b",
        "description": "Sequelize raw query / literal — bypasses parameterization",
        "expected_role": "sql_sink",
        "false_positive_notes": "Sequelize replacements/bind are safe; raw concat is dangerous."
      },
      {
        "id": "js-knex-raw",
        "pattern": "\\bknex\\.raw\\s*\\(|\\b\\.raw\\s*\\(\\s*`[^`]*\\$\\{",
        "description": "Knex raw() with interpolation — SQLi vector",
        "expected_role": "sql_sink",
        "false_positive_notes": "knex.raw with bindings array (?? / ?) is safe; template interpolation is not."
      },
      {
        "id": "js-typeorm-raw",
        "pattern": "\\b(?:getRepository|getManager|getConnection)\\s*\\([^)]*\\)\\s*\\.query\\s*\\(|\\bcreateQueryBuilder\\s*\\([^)]*\\)\\.where\\s*\\(\\s*`[^`]*\\$\\{",
        "description": "TypeORM raw query / unparameterized where",
        "expected_role": "sql_sink",
        "false_positive_notes": "TypeORM query() with params is safe; .where(`x = ${y}`) is not."
      },
      {
        "id": "js-mongoose-where-js",
        "pattern": "\\b(?:Model|Schema)\\.find\\s*\\(\\s*\\{[^}]*\\$where",
        "description": "Mongoose $where operator — accepts JS string, server-side JS execution",
        "expected_role": "nosql_sink",
        "false_positive_notes": "$where with user input is RCE on MongoDB server (legacy)."
      },
      {
        "id": "js-yaml-unsafe-load",
        "pattern": "\\byaml\\.load\\s*\\(|\\bjsYaml\\.load\\s*\\(|\\bload\\s*\\(\\s*\\w+\\s*,\\s*\\{\\s*schema:\\s*yaml\\.DEFAULT_FULL_SCHEMA",
        "description": "js-yaml unsafe load — older versions deserialize JS code from YAML !!js/function tags",
        "expected_role": "deserialization_sink",
        "false_positive_notes": "yaml.load deprecated in v4+; use yaml.safeLoad / yaml.load(s, {schema: SAFE_SCHEMA})."
      },
      {
        "id": "js-serialize-javascript",
        "pattern": "\\b(?:node-serialize|serialize-javascript|serialize\\s*\\(\\s*\\w+\\s*\\)|\\bunserialize\\s*\\()",
        "description": "node-serialize unserialize — known RCE if called on attacker input (CVE-2017-5941 lineage)",
        "expected_role": "deserialization_sink",
        "false_positive_notes": "node-serialize is unmaintained; presence is suspicious."
      }
    ],
    "python": [
      {
        "id": "py-raw-sql",
        "pattern": "\\.(?:execute|executemany|raw|raw_query)\\s*\\(\\s*[fr]?['\"](?:SELECT|INSERT|UPDATE|DELETE|MERGE)",
        "description": "Python raw SQL execution",
        "expected_role": "sql_sink",
        "false_positive_notes": "Check parameter binding."
      },
      {
        "id": "py-fstring-sql",
        "pattern": "\\.(?:execute|raw)\\s*\\(\\s*f['\"]",
        "description": "Python f-string SQL — interpolation vulnerable",
        "expected_role": "sql_sink",
        "false_positive_notes": "Almost always a finding."
      },
      {
        "id": "py-subprocess-shell",
        "pattern": "\\bsubprocess\\.(?:run|call|Popen|check_output|check_call)\\s*\\([^)]*shell\\s*=\\s*True",
        "description": "Python subprocess with shell=True",
        "expected_role": "command_sink",
        "false_positive_notes": "Almost always worth review."
      },
      {
        "id": "py-os-shell",
        "pattern": "\\bos\\.(?:system|popen)\\s*\\(",
        "description": "Python os.system / os.popen — invokes a shell",
        "expected_role": "command_sink",
        "false_positive_notes": "Inherently risky."
      },
      {
        "id": "py-eval-exec",
        "pattern": "\\b(?:eval|exec|compile)\\s*\\(",
        "description": "Python dynamic code execution",
        "expected_role": "eval_sink",
        "false_positive_notes": "Always worth review."
      },
      {
        "id": "py-jinja-render",
        "pattern": "\\bTemplate\\s*\\(\\s*\\w+\\s*\\)|\\brender_template_string\\s*\\(",
        "description": "Jinja template construction / render-from-string",
        "expected_role": "ssti_sink",
        "false_positive_notes": "Concern: template string from input."
      }
    ],
    "go": [
      {
        "id": "go-raw-sql-format",
        "pattern": "\\bfmt\\.Sprintf\\s*\\([^)]*(?:SELECT|INSERT|UPDATE|DELETE)\\b",
        "description": "Go SQL via Sprintf — interpolation vulnerable",
        "expected_role": "sql_sink",
        "false_positive_notes": "Almost always a finding."
      },
      {
        "id": "go-exec-command",
        "pattern": "\\bexec\\.Command(?:Context)?\\s*\\(\\s*['\"](?:/bin/sh|sh|bash)['\"]",
        "description": "Go exec.Command invoking a shell",
        "expected_role": "command_sink",
        "false_positive_notes": "Stable."
      }
    ],
    "php": [
      {
        "id": "php-mysql-query",
        "pattern": "\\bmysql(?:i)?_query\\s*\\(|->query\\s*\\(\\s*['\"](?:SELECT|INSERT|UPDATE|DELETE)",
        "description": "PHP raw SQL",
        "expected_role": "sql_sink",
        "false_positive_notes": "Stable."
      },
      {
        "id": "php-exec-funcs",
        "pattern": "\\b(?:exec|shell_exec|system|passthru|popen|proc_open|eval)\\s*\\(",
        "description": "PHP command / eval functions",
        "expected_role": "command_sink",
        "false_positive_notes": "Inherently risky."
      },
      {
        "id": "php-wpdb-query-no-prepare",
        "pattern": "\\$wpdb->(?:query|get_results|get_row|get_var|get_col)\\s*\\(\\s*['\"]",
        "description": "WordPress $wpdb direct query (vs $wpdb->prepare)",
        "expected_role": "sql_sink",
        "false_positive_notes": "Should use $wpdb->prepare with placeholders."
      },
      {
        "id": "php-laravel-db-raw",
        "pattern": "\\b(?:DB::raw|DB::select|DB::statement)\\s*\\(\\s*['\"][^'\"]*['\"]\\s*\\.|->whereRaw\\s*\\(|->selectRaw\\s*\\(",
        "description": "Laravel DB raw with concat — bypass query builder",
        "expected_role": "sql_sink",
        "false_positive_notes": "Almost always a finding."
      },
      {
        "id": "php-preg-replace-eval",
        "pattern": "\\bpreg_replace\\s*\\(\\s*['\"][^'\"]*/[a-zA-Z]*e[a-zA-Z]*['\"]\\s*,",
        "description": "preg_replace with /e modifier — code eval (deprecated PHP 5.5+, removed 7.0)",
        "expected_role": "eval_sink",
        "false_positive_notes": "Critical when present in legacy code."
      },
      {
        "id": "php-include-variable",
        "pattern": "\\b(?:include|include_once|require|require_once)\\s*\\(\\s*\\$",
        "description": "Dynamic include with variable — LFI/RFI",
        "expected_role": "eval_sink",
        "false_positive_notes": "Investigate variable source."
      },
      {
        "id": "php-twig-template-from-string",
        "pattern": "\\bTwig\\\\Environment|->createTemplate\\s*\\(\\s*\\$|->render\\s*\\(\\s*['\"][^'\"]*\\{\\{",
        "description": "Twig template from user input — SSTI",
        "expected_role": "ssti_sink",
        "false_positive_notes": "Risk when template string is user-controlled."
      },
      {
        "id": "php-laravel-blade-unescape",
        "pattern": "\\{!!.*!!\\}|@php\\s+echo|->html\\s*\\(",
        "description": "Laravel Blade unescaped output {!! !!} — XSS",
        "expected_role": "html_sink",
        "false_positive_notes": "Investigate input source."
      },
      {
        "id": "php-ssi-assert-string",
        "pattern": "\\bassert\\s*\\(\\s*['\"]",
        "description": "assert() with string argument — eval()-equivalent in older PHP. Allows code execution if string is user-influenced. Removed in PHP 8.",
        "expected_role": "eval_sink",
        "false_positive_notes": "Most assert() calls take boolean expressions; string-arg form is rare and high-confidence dangerous."
      },
      {
        "id": "php-ssi-create-function",
        "pattern": "\\bcreate_function\\s*\\(",
        "description": "create_function() — legacy PHP 5 dynamic function compilation, eval()-based. Removed in PHP 8.",
        "expected_role": "eval_sink",
        "false_positive_notes": "Modern code should never use this. Hits indicate legacy code in need of migration."
      },
      {
        "id": "php-ssi-callable-userland-injection",
        "pattern": "\\b(?:call_user_func(?:_array)?|usort|uasort|uksort|array_map|array_filter|array_walk(?:_recursive)?|array_reduce)\\s*\\(\\s*\\$",
        "description": "Variable callable — call_user_func / array_map with user-influenced callable name allows arbitrary function invocation",
        "expected_role": "eval_sink",
        "false_positive_notes": "Many legitimate uses with hardcoded callables. The risk is when first arg is a request-derived string."
      },
      {
        "id": "php-ssi-doctrine-dql-concat",
        "pattern": "->createQuery\\s*\\(\\s*['\"][^'\"]*['\"]\\s*\\.|->createNativeQuery\\s*\\(\\s*['\"][^'\"]*['\"]\\s*\\.",
        "description": "Doctrine DQL/Native query built by string concatenation — bypasses parameterisation. SQLi.",
        "expected_role": "sql_sink",
        "false_positive_notes": "If the concatenated portion is a column name (whitelisted), false positive; if a value, real SQLi."
      },
      {
        "id": "php-ssi-symfony-process-shell",
        "pattern": "\\bnew\\s+Process\\s*\\(\\s*['\"][^'\"]*\\$|\\bProcess::fromShellCommandline\\s*\\(",
        "description": "Symfony Process with shell-string interpolation — command injection if user data flows in",
        "expected_role": "shell_sink",
        "false_positive_notes": "Process with array arg is safe; the dangerous form is string with interpolation or fromShellCommandline."
      },
      {
        "id": "php-ssi-wp-ajax-callback-shortcode",
        "pattern": "\\b(?:add_shortcode|wp_ajax_\\w+|add_action\\s*\\(\\s*['\"]wp_ajax)\\b",
        "description": "WordPress shortcode + AJAX callback registration — entry points for untrusted user input into PHP execution",
        "expected_role": "input_source",
        "false_positive_notes": "Stable WP API; investigate the registered callbacks for SQLi/RCE."
      }
    ],
    "java": [
      {
        "id": "java-statement",
        "pattern": "\\b(?:Statement|createStatement)\\b|\\.executeQuery\\s*\\(\\s*['\"](?:SELECT|INSERT|UPDATE|DELETE)",
        "description": "Java Statement (vs PreparedStatement)",
        "expected_role": "sql_sink",
        "false_positive_notes": "Statement = no param binding; check PreparedStatement is used instead."
      },
      {
        "id": "java-runtime-exec",
        "pattern": "\\bRuntime\\.getRuntime\\(\\)\\.exec\\s*\\(|\\bProcessBuilder\\s*\\(",
        "description": "Java process execution",
        "expected_role": "command_sink",
        "false_positive_notes": "Stable."
      },
      {
        "id": "java-jpa-createquery-concat",
        "pattern": "\\.createQuery\\s*\\(\\s*['\"][^'\"]*['\"]\\s*\\+|\\.createNativeQuery\\s*\\(\\s*['\"][^'\"]*['\"]\\s*\\+",
        "description": "JPA createQuery / createNativeQuery with string concat — HQL/JPQL injection",
        "expected_role": "sql_sink",
        "false_positive_notes": "Almost always a finding when concat is present."
      },
      {
        "id": "java-jdbc-execute-concat",
        "pattern": "\\.(?:executeQuery|executeUpdate|execute)\\s*\\(\\s*['\"][^'\"]*['\"]\\s*\\+|\\.executeQuery\\s*\\(\\s*\\w+\\s*\\+",
        "description": "JDBC execute with string concat — SQL injection",
        "expected_role": "sql_sink",
        "false_positive_notes": "Stable; if concat involves user input it's exploitable."
      },
      {
        "id": "java-spring-jdbctemplate-format",
        "pattern": "\\bjdbcTemplate\\.(?:query|update|execute)\\s*\\(\\s*String\\.format|\\bjdbcTemplate\\.\\w+\\s*\\(\\s*['\"][^'\"]*['\"]\\s*\\+",
        "description": "Spring JdbcTemplate with String.format / concat — bypasses parameter binding",
        "expected_role": "sql_sink",
        "false_positive_notes": "Should use ? placeholders + args."
      },
      {
        "id": "java-mybatis-raw",
        "pattern": "\\$\\{[^}]*\\}|<select[^>]*>\\s*[^<]*\\$\\{",
        "description": "MyBatis ${} variable interpolation (vs #{} prepared)",
        "expected_role": "sql_sink",
